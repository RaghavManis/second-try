# Instructions for Local Phone/Network Data Access
# -----------------------------------------------------------------------------------------
# HOW TO CONNECT YOUR PHONE OVER WIFI:
# 
# 1. Ensure your PC running the code & Phone are on the EXACT SAME WiFi network.
# 2. Open Command Prompt / Terminal on your PC
#    - Windows: type `ipconfig` and look for "IPv4 Address" (e.g., 192.168.1.15)
#    - Mac/Linux: type `ifconfig` or `ipconfig getifaddr en0`
# 3. Create a duplicate of this file in the same folder and literally name it exactly `.env.local`
# 4. Open `.env.local` and replace the IP inside it with the IPv4 from step 2.
# 5. Restart your frontend server (`npm run dev`)
# 6. Type the IP and port into your phone browser. e.g. `http://192.168.1.15:5173`
# -----------------------------------------------------------------------------------------

VITE_API_BASE_URL=http://192.168.X.X:8080/api
